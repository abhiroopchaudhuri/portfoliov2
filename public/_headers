# Netlify / Cloudflare Pages / static host header overrides.
# Keep immutable caching for long-lived assets so returning visitors don't
# re-download. `index.html` stays no-cache so new deploys are picked up
# immediately.

/hero/*
  Cache-Control: public, max-age=31536000, immutable

/frames/*
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/videos/*
  Cache-Control: public, max-age=31536000, immutable

/thumbnails/*
  Cache-Control: public, max-age=2592000

/logos/*
  Cache-Control: public, max-age=2592000

/
  Cache-Control: public, max-age=0, must-revalidate

/index.html
  Cache-Control: public, max-age=0, must-revalidate
